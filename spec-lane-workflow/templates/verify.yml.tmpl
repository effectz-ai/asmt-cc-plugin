name: Verify

# Hard verification gate: no PR merges red.
# Mirrors the local pre-PR gate ({{GATE_CMD}}).
# Generated by spec-lane-workflow /workflow-init.

on:
  pull_request:
    branches: [{{INTEGRATION_BRANCH}}, {{RELEASE_BRANCH}}]
  push:
    branches: [{{INTEGRATION_BRANCH}}, {{RELEASE_BRANCH}}]

concurrency:
  group: verify-${{ github.ref }}
  cancel-in-progress: true

jobs:
  verify:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
        with:
          fetch-depth: 0
{{PM_SETUP_STEPS}}
      - name: Gate — lint, types, test
        run: {{GATE_CMD}}